# ── Model provider ────────────────────────────────────────────────────────────
# Pick one of the following setups:

# 1. OpenAI (default)
OPENAI_API_KEY=sk-...
AGENT_MODEL=openai:gpt-4o-mini

# 2. Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# AGENT_MODEL=anthropic:claude-haiku-4-5-20251001

# 3. Ollama (local, free — run `ollama pull llama3` first)
# AGENT_MODEL=openai-compat:llama3
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama

# 4. Groq (fast, free tier)
# AGENT_MODEL=openai-compat:llama-3.1-70b-versatile
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_API_KEY=gsk_...

# 5. Together AI
# AGENT_MODEL=openai-compat:meta-llama/Llama-3-70b-chat-hf
# OPENAI_BASE_URL=https://api.together.xyz/v1
# OPENAI_API_KEY=...

# 6. OpenRouter (access 100+ models with one key)
# AGENT_MODEL=openai-compat:anthropic/claude-3.5-haiku
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-...

# Optional: web search (Brave Search API)
BRAVE_API_KEY=

# Optional: EVM testnet (Sepolia)
EVM_RPC_URL=https://sepolia.infura.io/v3/<key>
AGENT_PRIVATE_KEY=0x...   # testnet-only throwaway key
EVM_ALLOWLIST=0xRecipient1,0xRecipient2

# Optional: Logging
LOG_LEVEL=info
