# ═══════════════════════════════════════════════════════════════════════════════
#  Thiny — environment configuration
#  Copy to .env and fill in your values.
#  See thiny.config.example.json for a config-file alternative.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Model selection ────────────────────────────────────────────────────────────
# Pick ONE of the setups below. THINY_MODEL overrides thiny.config.json.

# 1. OpenAI
THINY_MODEL=openai:gpt-4o-mini
THINY_OPENAI_API_KEY=sk-...

# 2. Anthropic
# THINY_MODEL=anthropic:claude-haiku-4-5-20251001
# THINY_ANTHROPIC_API_KEY=sk-ant-...

# 3. Ollama  (local · free · run `ollama pull llama3` first)
# THINY_MODEL=llama3                            ← bare model ID, no prefix needed!
# THINY_OPENAI_BASE_URL=http://localhost:11434/v1
# THINY_OPENAI_API_KEY=ollama

# 4. LM Studio  (local · free · start LM Studio server first)
# THINY_MODEL=local-model
# THINY_OPENAI_BASE_URL=http://localhost:1234/v1
# THINY_OPENAI_API_KEY=lm-studio

# 5. Groq  (fast · generous free tier)
# THINY_MODEL=llama-3.1-70b-versatile
# THINY_OPENAI_BASE_URL=https://api.groq.com/openai/v1
# THINY_OPENAI_API_KEY=gsk_...

# 6. Together AI
# THINY_MODEL=meta-llama/Llama-3-70b-chat-hf
# THINY_OPENAI_BASE_URL=https://api.together.xyz/v1
# THINY_OPENAI_API_KEY=...

# 7. OpenRouter  (100+ models with one key)
# THINY_MODEL=anthropic/claude-3.5-haiku
# THINY_OPENAI_BASE_URL=https://openrouter.ai/api/v1
# THINY_OPENAI_API_KEY=sk-or-...

# 8. Mimo by Xiaomi
# THINY_MODEL=mimo-v2.5-pro                     ← just the model ID, no prefix!
# THINY_OPENAI_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
# THINY_OPENAI_API_KEY=your-mimo-key

# 9. Azure OpenAI
# THINY_MODEL=my-deployment-name
# THINY_OPENAI_BASE_URL=https://<resource>.openai.azure.com/openai/deployments/<name>
# THINY_OPENAI_API_KEY=...

# 10. Anthropic via proxy
# THINY_MODEL=claude-3-5-haiku-20241022
# THINY_ANTHROPIC_BASE_URL=https://my-proxy.example.com
# THINY_ANTHROPIC_API_KEY=proxy-key

# ── Optional features ──────────────────────────────────────────────────────────
BRAVE_API_KEY=              # enables web_search tool
LOG_LEVEL=info              # debug | info | warn | error

# ── Agent persona ──────────────────────────────────────────────────────────────
# Makes the agent always identify itself by this name regardless of which
# underlying model (OpenAI, Anthropic, Ollama, Mimo, etc.) is powering it.
THINY_PERSONA_NAME=ThinyAI
THINY_PERSONA_DESCRIPTION=a helpful AI assistant built on the Thiny framework
THINY_USER_ID=default       # cross-session memory is keyed by this — change per user
AUDIT_LOG=                  # write structured JSON audit trail to this file (e.g. audit.log)
THINY_LOG_FILE=             # CLI TUI log file path (default: ~/thiny-cli.log) — inspect with: tail -f ~/thiny-cli.log
SESSION_DB=file:thiny.sqlite # SQLite path for session persistence (default: file:thiny.sqlite)

# ── Web3 / EVM testnet ─────────────────────────────────────────────────────────
# EVM_RPC_URL=https://sepolia.infura.io/v3/<key>
# AGENT_PRIVATE_KEY=0x...   # testnet-only throwaway key
# EVM_ALLOWLIST=0xAddr1,0xAddr2

# ── Walrus (verifiable audit trail + artifacts) ─────────────────────────────────
# WALRUS_AUDIT=1 → CLI stores each turn's action log on Walrus and prints Walruscan/Suiscan links.
# WALRUS_AUDIT=1
# WALRUS_NETWORK=testnet      # testnet | mainnet — drives explorer URLs
# Public testnet endpoints — no WAL/SUI token needed. They rotate; pull fresh from
# docs.wal.app network-reference if PUTs start failing. Leave blank to use defaults.
# WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
# WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# ── MemWal (portable Walrus Memory) ─────────────────────────────────────────────
# Create an account + delegate key at the MemWal Playground.
# MEMWAL_DELEGATE_KEY=0x...   # hex delegate key
# MEMWAL_ACCOUNT_ID=
# MEMWAL_SERVER_URL=
# MEMWAL_NAMESPACE=my-agent   # share across agents for shared memory

# ── Sui on-chain memory-head (verifiable pointer; replaces local pointer.json) ───
# Publish move/memory_head, then `create` a shared MemoryHead object (see its README).
# When SUI_PACKAGE_ID + SUI_MEMORY_HEAD_ID are set, walrus-demo stores the pointer on-chain.
# SUI_PACKAGE_ID=0x...
# SUI_MEMORY_HEAD_ID=0x...
# SUI_RPC_URL=https://fullnode.testnet.sui.io:443
# SUI_SECRET_KEY=suiprivkey1...   # owner/agent key (from `sui keytool export`) — required to sign
# THINY_SUI_SECRET_KEY=suiprivkey1...  # funded testnet key for scripts/sui-signer-smoke.ts (live sign proof)
# SUI_NETWORK=testnet             # testnet | mainnet (suiSigner)
# SUI_ALLOW_MAINNET=              # set to 1 to opt the signer into mainnet (guard is off by default)

# ── Rill MCP (grounded Sui execution) ───────────────────────────────────────────
# The Rill MCP URL is PER-USER and dynamic — each user gets their own from Rill and Thiny
# obtains it at runtime (via `thiny init` pairing → /me/agents/:id, cached in ~/.thiny/).
# It is NOT configured here. The agent passes it to mcpHttpPlugin({ url }) at startup.
# MCP_URL below is ONLY an optional override for local single-user dev/testing.
# MCP_URL=https://your-rill-host/mcp/flow/<id>

# ── walrus-demo head ─────────────────────────────────────────────────────────────
# TICK_MS=60000               # interval between monitoring ticks
# MAX_RUNS=                   # stop after N ticks (default: unlimited)
# WALRUS_POINTERS=thiny-pointers.json   # local pointer file (ignored when SUI_* set)
