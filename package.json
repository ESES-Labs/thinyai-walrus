{
  "name": "thiny",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -b && tsc -b --clean",
    "cli": "node --env-file=.env --import tsx heads/cli/src/main.ts",
    "create-thiny": "node --import tsx apps/create-thiny/src/index.ts",
    "lint": "tsc -b --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "packageManager": "pnpm@9.6.0"
}
